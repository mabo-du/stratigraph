<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi" xmlns:fw="http://schemas.microsoft.com/wix/FirewallExtension">
  <Fragment>
    <DirectoryRef Id="INSTALLDIR">
      <Component Id="FirewallException" Guid="*">
        <fw:FirewallException Id="StratiGraphFW"
                              Name="StratiGraph"
                              Program="[INSTALLDIR]StratiGraph.exe"
                              Scope="any"
                              Profile="all"
                              IgnoreFailure="yes" />
      </Component>
    </DirectoryRef>
  </Fragment>
</Wix>
